<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Terminal Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#111111"
        android:padding="10dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_current_dir"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="root@android:/data/local/tmp"
            android:textColor="#00FF41"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:ellipsize="start"
            android:singleLine="true" />

        <Button
            android:id="@+id/btn_clear_terminal"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="Clear"
            android:textSize="11sp"
            android:textColor="#E94560"
            android:background="@android:color/transparent"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />
    </LinearLayout>

    <!-- Output Area -->
    <ScrollView
        android:id="@+id/scroll_output"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:fadeScrollbars="false"
        android:scrollbarStyle="insideOverlay">

        <TextView
            android:id="@+id/tv_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCFFCC"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.2"
            android:text="GoMode Root Shell\nType commands below. Root access required.\n\n$ " />
    </ScrollView>

    <!-- Input Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#111111"
        android:gravity="center_vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="# "
            android:textColor="#E94560"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="4dp" />

        <EditText
            android:id="@+id/et_command"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:textColor="#00FF41"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:hint="enter command..."
            android:textColorHint="#444444"
            android:imeOptions="actionSend"
            android:inputType="text|textNoSuggestions"
            android:maxLines="1"
            android:singleLine="true" />

        <ImageButton
            android:id="@+id/btn_history_up"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/arrow_up_float"
            android:tint="#606080"
            android:contentDescription="Previous command" />

        <ImageButton
            android:id="@+id/btn_history_down"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/arrow_down_float"
            android:tint="#606080"
            android:contentDescription="Next command" />

        <Button
            android:id="@+id/btn_run"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Run"
            android:textSize="12sp"
            android:textColor="#000000"
            android:backgroundTint="@color/accent"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </LinearLayout>

</LinearLayout>
