<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- App Header -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_shield"
            android:tint="@color/accent"
            android:layout_marginTop="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GoMode"
            android:textColor="@color/accent"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kernel-Level Privacy Control"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/accent"
            android:layout_marginTop="40dp"
            android:visibility="visible" />

        <!-- Status Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_root_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/bg_card"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/img_status_icon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/checkbox_on_background"
                    android:tint="@color/green_success" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detecting Root..."
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tv_status_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="12dp"
                    android:gravity="start" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Info Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/bg_card_elevated">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How GoMode Works"
                    android:textColor="@color/accent"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Operates at kernel level using native C++ hooks\n• Intercepts Binder IPC calls in real-time\n• Monitors all app data access (IMEI, location, etc.)\n• No LSPosed/Xposed dependency\n• Requires root for system-level monitoring"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Buttons Layout -->
        <LinearLayout
            android:id="@+id/layout_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_continue_with_root"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Continue Setup"
                android:backgroundTint="@color/accent"
                android:textColor="@color/bg_dark"
                android:textStyle="bold"
                android:padding="16dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_request_root"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Request Root Access"
                android:backgroundTint="@color/accent"
                android:textColor="@color/bg_dark"
                android:textStyle="bold"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_open_root_manager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open Root Manager"
                android:backgroundTint="@color/blue_info"
                android:textColor="@color/text_primary"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_continue_without_root"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Continue Without Root (Limited)"
                android:backgroundTint="@color/bg_card_elevated"
                android:textColor="@color/text_secondary"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
