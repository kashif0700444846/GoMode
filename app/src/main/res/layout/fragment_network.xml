<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        android:background="@color/bg_card">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Network Control"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Live connectivity, firewall, DNS and runtime ops"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_network"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:indeterminateTint="@color/accent"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btn_refresh_network"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_refresh"
            android:tint="@color/text_secondary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Refresh" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="84dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/bg_card_elevated"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIVE SNAPSHOT"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tv_network_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Loading live status..."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.35" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                style="@style/GodMode.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUICK TOGGLES"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="WiFi"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                        <Switch
                            android:id="@+id/switch_wifi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:thumbTint="@color/accent"
                            android:trackTint="@color/divider" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mobile Data"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                        <Switch
                            android:id="@+id/switch_mobile_data"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:thumbTint="@color/accent"
                            android:trackTint="@color/divider" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Hotspot"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                        <Switch
                            android:id="@+id/switch_hotspot"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:thumbTint="@color/accent"
                            android:trackTint="@color/divider" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Bluetooth"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                        <Switch
                            android:id="@+id/switch_bluetooth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:thumbTint="@color/accent"
                            android:trackTint="@color/divider" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Airplane Mode"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                        <Switch
                            android:id="@+id/switch_airplane_mode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:thumbTint="@color/accent"
                            android:trackTint="@color/divider" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                style="@style/GodMode.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="WIRELESS DETAILS"
                            android:textColor="@color/text_hint"
                            android:textSize="10sp"
                            android:letterSpacing="0.1" />

                        <Button
                            android:id="@+id/btn_scan_wifi"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Scan"
                            android:textSize="11sp"
                            style="@style/GodMode.Button" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_wifi_details"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.35"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_wifi_networks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tap Scan to find nearby networks"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.35" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                style="@style/GodMode.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MOBILE + DNS"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_mobile_details"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.35" />

                    <TextView
                        android:id="@+id/tv_dns_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="DNS: Loading..."
                        android:textColor="@color/accent"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                style="@style/GodMode.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NETWORK TOOLS"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <Button
                            android:id="@+id/btn_connections"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="Connections"
                            android:textSize="11sp"
                            style="@style/GodMode.Button.Outlined" />

                        <Button
                            android:id="@+id/btn_iptables"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="Firewall"
                            android:textSize="11sp"
                            style="@style/GodMode.Button.Outlined" />

                        <Button
                            android:id="@+id/btn_traffic_stats"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="Traffic"
                            android:textSize="11sp"
                            style="@style/GodMode.Button.Outlined" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_set_dns"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="Set DNS"
                            android:textSize="11sp"
                            style="@style/GodMode.Button" />

                        <Button
                            android:id="@+id/btn_edit_hosts"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="Edit /etc/hosts"
                            android:textSize="11sp"
                            style="@style/GodMode.Button.Outlined" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/GodMode.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SYSTEM PROPERTIES"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_build_props"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="View Props"
                            android:textSize="11sp"
                            style="@style/GodMode.Button.Outlined" />

                        <Button
                            android:id="@+id/btn_resetprop"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="Set Property"
                            android:textSize="11sp"
                            style="@style/GodMode.Button" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
