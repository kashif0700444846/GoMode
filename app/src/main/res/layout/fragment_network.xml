<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Network &amp; System" android:textColor="@color/text_primary"
                android:textSize="20sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="WiFi, mobile data, DNS, firewall, system properties"
                android:textColor="@color/text_hint" android:textSize="11sp" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <ProgressBar android:id="@+id/progress_network" android:layout_width="24dp"
            android:layout_height="24dp" android:indeterminateTint="@color/accent"
            android:visibility="gone"/>

        <ImageButton android:id="@+id/btn_refresh_network" android:layout_width="36dp"
            android:layout_height="36dp" android:src="@drawable/ic_refresh"
            android:tint="@color/text_secondary" android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Refresh"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp">

            <!-- Quick Toggles Card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="10dp"
                style="@style/GodMode.CardView">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="QUICK TOGGLES" android:textColor="@color/text_hint"
                        android:textSize="10sp" android:letterSpacing="0.12" android:layout_marginBottom="8dp"/>

                    <!-- WiFi row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="WiFi" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <Switch android:id="@+id/switch_wifi" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:thumbTint="@color/accent" android:trackTint="@color/divider"/>
                    </LinearLayout>

                    <!-- Mobile Data row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Mobile Data" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <Switch android:id="@+id/switch_mobile_data" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:thumbTint="@color/accent" android:trackTint="@color/divider"/>
                    </LinearLayout>

                    <!-- Hotspot row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Hotspot / Tethering" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <Switch android:id="@+id/switch_hotspot" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:thumbTint="@color/accent" android:trackTint="@color/divider"/>
                    </LinearLayout>

                    <!-- Bluetooth row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Bluetooth" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <Switch android:id="@+id/switch_bluetooth" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:thumbTint="@color/accent" android:trackTint="@color/divider"/>
                    </LinearLayout>

                    <!-- Airplane Mode row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Airplane Mode" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <Switch android:id="@+id/switch_airplane_mode" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:thumbTint="@color/accent" android:trackTint="@color/divider"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- WiFi Networks Card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="10dp"
                style="@style/GodMode.CardView">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="WIFI NETWORKS"
                            android:textColor="@color/text_hint" android:textSize="10sp" android:letterSpacing="0.12"/>
                        <Button android:id="@+id/btn_scan_wifi" android:layout_width="wrap_content"
                            android:layout_height="32dp" android:text="Scan" android:textSize="11sp"
                            style="@style/GodMode.Button"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tv_wifi_details" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                        android:textSize="12sp" android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.4" android:text="Loading..." android:layout_marginBottom="8dp"/>
                    <TextView android:id="@+id/tv_wifi_networks" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:textColor="@color/text_hint"
                        android:textSize="11sp" android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.4" android:text="Tap Scan to find networks"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Mobile Data Card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="10dp"
                style="@style/GodMode.CardView">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="MOBILE DATA &amp; SIGNAL"
                        android:textColor="@color/text_hint" android:textSize="10sp"
                        android:letterSpacing="0.12" android:layout_marginBottom="8dp"/>
                    <TextView android:id="@+id/tv_mobile_details" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                        android:textSize="12sp" android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.4" android:text="Loading..."/>
                    <TextView android:id="@+id/tv_dns_info" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:textColor="@color/accent"
                        android:textSize="12sp" android:layout_marginTop="6dp"
                        android:text="DNS: Loading..."/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Network Tools -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="10dp"
                style="@style/GodMode.CardView">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="NETWORK TOOLS" android:textColor="@color/text_hint"
                        android:textSize="10sp" android:letterSpacing="0.12" android:layout_marginBottom="8dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <Button android:id="@+id/btn_connections" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:text="Connections" android:textSize="11sp" style="@style/GodMode.Button.Outlined"/>
                        <Button android:id="@+id/btn_iptables" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:text="Firewall" android:textSize="11sp" style="@style/GodMode.Button.Outlined"/>
                        <Button android:id="@+id/btn_traffic_stats" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Traffic" android:textSize="11sp" style="@style/GodMode.Button.Outlined"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <Button android:id="@+id/btn_set_dns" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:text="Set DNS" android:textSize="11sp" style="@style/GodMode.Button"/>
                        <Button android:id="@+id/btn_edit_hosts" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Edit /etc/hosts" android:textSize="11sp" style="@style/GodMode.Button.Outlined"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- System Properties -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="80dp"
                style="@style/GodMode.CardView">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SYSTEM PROPERTIES (setprop/resetprop)"
                        android:textColor="@color/text_hint" android:textSize="10sp"
                        android:letterSpacing="0.12" android:layout_marginBottom="8dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <Button android:id="@+id/btn_build_props" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:text="View Props" android:textSize="11sp" style="@style/GodMode.Button.Outlined"/>
                        <Button android:id="@+id/btn_resetprop" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Set Property" android:textSize="11sp" style="@style/GodMode.Button"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
