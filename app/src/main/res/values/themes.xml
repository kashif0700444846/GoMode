<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GodMode" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent_light</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.GodMode.Dialog</item>
    </style>

    <style name="ThemeOverlay.GodMode.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">@color/bg_card</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
    </style>

    <!-- Base GodMode style required by AAPT2 for dot-notation child styles -->
    <style name="GodMode" parent="Theme.GodMode" />

    <style name="GodMode.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">12dp</item>
    </style>

    <style name="GodMode.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="GodMode.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/accent</item>
        <item name="android:textColor">@color/accent</item>
    </style>

    <style name="GodMode.Chip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_bg</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

    <style name="GodMode.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <style name="GodMode.Spinner" parent="Widget.AppCompat.Spinner">
        <item name="android:background">@color/bg_card_elevated</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="GodMode.StatusBadge">
        <item name="android:textSize">10sp</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:paddingBottom">2dp</item>
        <item name="android:background">@drawable/bg_badge</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>
